    {
      "id": "install-nginx-web-server",
      "entity_type": "task",
      "content_level": "workflow",
      "title_ar": "تثبيت وتشغيل خادم Nginx",
      "goal_ar": "أريد تجهيز خادم ويب Nginx",
      "summary_ar": "تثبيت Nginx وتشغيله وفتح HTTP ثم اختبار الاستجابة.",
      "category": "web_servers",
      "difficulty": "beginner",
      "estimated_minutes": 10,
      "keywords_ar": [
        "nginx",
        "خادم ويب",
        "ويب سيرفر",
        "http"
      ],
      "supported_versions": [
        "8",
        "9",
        "10"
      ],
      "risk": "high",
      "prerequisites_ar": [
        "صلاحية sudo",
        "عدم استخدام المنفذ 80 من خدمة أخرى"
      ],
      "variables": [],
      "steps": [
        {
          "id": "install",
          "title_ar": "تثبيت Nginx",
          "command": "sudo dnf install nginx",
          "explanation_ar": "يثبت حزمة Nginx.",
          "requires_sudo": true,
          "risk": "medium",
          "optional": false,
          "expected_result_ar": "اكتمال التثبيت.",
          "notes_ar": ""
        },
        {
          "id": "enable",
          "title_ar": "تشغيل الخدمة الآن ومع الإقلاع",
          "command": "sudo systemctl enable --now nginx",
          "explanation_ar": "يشغل الخدمة ويفعلها مع الإقلاع.",
          "requires_sudo": true,
          "risk": "high",
          "optional": false,
          "expected_result_ar": "الخدمة active.",
          "notes_ar": ""
        },
        {
          "id": "firewall",
          "title_ar": "السماح بخدمة HTTP",
          "command": "sudo firewall-cmd --permanent --add-service=http",
          "explanation_ar": "يسمح باتصالات HTTP.",
          "requires_sudo": true,
          "risk": "high",
          "optional": false,
          "expected_result_ar": "success",
          "notes_ar": ""
        },
        {
          "id": "reload",
          "title_ar": "تطبيق قواعد الجدار الناري",
          "command": "sudo firewall-cmd --reload",
          "explanation_ar": "يعيد تحميل القواعد.",
          "requires_sudo": true,
          "risk": "medium",
          "optional": false,
          "expected_result_ar": "success",
          "notes_ar": ""
        },
        {
          "id": "test",
          "title_ar": "اختبار الاستجابة",
          "command": "curl -I http://localhost",
          "explanation_ar": "يفحص استجابة الخادم محلياً.",
          "requires_sudo": false,
          "risk": "low",
          "optional": false,
          "expected_result_ar": "HTTP 200 أو استجابة صحيحة.",
          "notes_ar": ""
        }
      ],
      "verification": [
        {
          "title_ar": "حالة الخدمة",
          "command": "systemctl status nginx",
          "expected_result_ar": "active (running)",
          "requires_sudo": false
        },
        {
          "title_ar": "فحص HTTP",
          "command": "curl -I http://localhost",
          "expected_result_ar": "استجابة HTTP",
          "requires_sudo": false
        }
      ],
      "rollback_ar": [
        "sudo systemctl disable --now nginx",
        "sudo dnf remove nginx"
      ],
      "common_errors": [
        {
          "symptom_ar": "الخدمة تفشل عند التشغيل",
          "likely_causes_ar": [
            "المنفذ 80 مستخدم",
            "خطأ في الإعداد"
          ],
          "checks": [
            {
              "title_ar": "حالة الخدمة",
              "command": "systemctl status nginx",
              "expected_result_ar": "سبب الفشل.",
              "requires_sudo": false
            },
            {
              "title_ar": "السجل",
              "command": "journalctl -u nginx -b --no-pager",
              "expected_result_ar": "رسائل الخطأ.",
              "requires_sudo": false
            },
            {
              "title_ar": "اختبار الإعداد",
              "command": "sudo nginx -t",
              "expected_result_ar": "syntax is ok",
              "requires_sudo": true
            }
          ],
          "fixes_ar": [
            "حرر المنفذ أو غيّر listen",
            "صحح ملف الإعداد"
          ]
        }
      ],
      "files": [
        "/etc/nginx/nginx.conf",
        "/etc/nginx/conf.d/",
        "/usr/share/nginx/html/"
      ],
      "ports": [
        {
          "port": 80,
          "protocol": "tcp",
          "purpose_ar": "HTTP"
        },
        {
          "port": 443,
          "protocol": "tcp",
          "purpose_ar": "HTTPS"
        }
      ],
      "related_tasks": [
        "troubleshoot-systemd-service",
        "open-firewall-port"
      ],
      "safety_notes_ar": [
        "فتح المنافذ يغيّر سطح الوصول إلى الخادم."
      ],
