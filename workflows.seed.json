      "status": "draft"
    },
    {
      "id": "troubleshoot-systemd-service",
      "entity_type": "task",
      "content_level": "troubleshooting",
      "title_ar": "تشخيص خدمة Systemd لا تعمل",
      "goal_ar": "أريد معرفة سبب توقف خدمة",
      "summary_ar": "فحص الحالة والسجل وملف الوحدة والمنافذ ثم إعادة الاختبار.",
      "category": "services",
      "difficulty": "intermediate",
      "estimated_minutes": 15,
      "keywords_ar": [
        "الخدمة لا تعمل",
        "service failed",
        "systemctl",
        "journalctl"
      ],
      "supported_versions": [
        "8",
        "9",
        "10"
      ],
      "risk": "medium",
      "prerequisites_ar": [
        "معرفة اسم الخدمة"
      ],
      "variables": [
        {
          "name": "SERVICE",
          "label_ar": "اسم الخدمة",
          "example": "nginx",
          "required": true
        }
      ],
      "steps": [
        {
          "id": "status",
          "title_ar": "عرض الحالة",
          "command": "systemctl status <SERVICE> --no-pager -l",
          "explanation_ar": "يعرض الحالة وآخر الرسائل.",
          "requires_sudo": false,
          "risk": "low",
          "optional": false,
          "expected_result_ar": "سبب أولي للفشل.",
          "notes_ar": ""
        },
        {
          "id": "logs",
          "title_ar": "عرض سجل الإقلاع الحالي",
          "command": "journalctl -u <SERVICE> -b --no-pager",
          "explanation_ar": "يعرض رسائل الخدمة منذ آخر إقلاع.",
          "requires_sudo": false,
          "risk": "low",
          "optional": false,
          "expected_result_ar": "رسائل تشخيصية.",
          "notes_ar": ""
        },
        {
          "id": "unit",
          "title_ar": "عرض ملف الوحدة",
          "command": "systemctl cat <SERVICE>",
          "explanation_ar": "يعرض ملف الوحدة والـ overrides.",
          "requires_sudo": false,
          "risk": "low",
          "optional": false,
          "expected_result_ar": "إعدادات التشغيل.",
          "notes_ar": ""
        },
        {
          "id": "ports",
          "title_ar": "فحص المنافذ",
          "command": "sudo ss -tulpn",
          "explanation_ar": "يكشف تعارض المنافذ.",
          "requires_sudo": true,
          "risk": "low",
          "optional": true,
          "expected_result_ar": "قائمة المنافذ.",
          "notes_ar": ""
        },
        {
          "id": "restart",
          "title_ar": "إعادة التشغيل بعد الإصلاح",
          "command": "sudo systemctl restart <SERVICE>",
          "explanation_ar": "يعيد تشغيل الخدمة بعد معالجة السبب.",
          "requires_sudo": true,
          "risk": "high",
          "optional": true,
          "expected_result_ar": "الخدمة active.",
          "notes_ar": ""
        }
      ],
      "verification": [
        {
          "title_ar": "الحالة النهائية",
          "command": "systemctl is-active <SERVICE>",
          "expected_result_ar": "active",
          "requires_sudo": false
        }
      ],
      "rollback_ar": [
        "ارجع آخر تعديل قبل إعادة المحاولة."
      ],
      "common_errors": [
        {
          "symptom_ar": "Unit not found",
          "likely_causes_ar": [
            "اسم الخدمة غير صحيح",
            "الحزمة غير مثبتة"
          ],
          "checks": [
            {
              "title_ar": "البحث عن الوحدة",
              "command": "systemctl list-unit-files | grep -i <SERVICE>",
              "expected_result_ar": "اسم الوحدة الصحيح.",
              "requires_sudo": false
            },
            {
              "title_ar": "البحث عن الحزمة",
              "command": "dnf search <SERVICE>",
              "expected_result_ar": "حزمة محتملة.",
              "requires_sudo": false
            }
          ],
          "fixes_ar": [
            "استخدم اسم الوحدة الصحيح",
            "ثبت الحزمة التي توفر الخدمة"
          ]
        }
      ],
      "files": [
        "/etc/systemd/system/",
        "/usr/lib/systemd/system/"
      ],
      "ports": [],
      "related_tasks": [
        "install-nginx-web-server"
      ],
      "safety_notes_ar": [
        "إعادة تشغيل خدمة إنتاجية قد تسبب انقطاعاً مؤقتاً."
      ],
      "sources": [],
      "status": "reviewed"
    },
    {
      "id": "create-user-with-admin-access",
