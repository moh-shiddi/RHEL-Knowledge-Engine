    {
      "id": "find-and-clean-large-files",
      "entity_type": "task",
      "content_level": "workflow",
      "title_ar": "العثور على سبب امتلاء القرص",
      "goal_ar": "أريد معرفة ما الذي يستهلك مساحة كبيرة",
      "summary_ar": "تحديد القسم الممتلئ ثم تحليل المجلدات والملفات الكبيرة قبل الحذف.",
      "category": "storage",
      "difficulty": "intermediate",
      "estimated_minutes": 12,
      "keywords_ar": [
        "الهارد ممتلئ",
        "مساحة القرص",
        "ملفات كبيرة",
        "disk full",
        "du",
        "find"
      ],
      "supported_versions": [
        "8",
        "9",
        "10"
      ],
      "risk": "medium",
      "prerequisites_ar": [
        "عدم حذف ملف قبل معرفة وظيفته"
      ],
      "variables": [
        {
          "name": "PATH",
          "label_ar": "المسار المراد تحليله",
          "example": "/var",
          "required": true
        }
      ],
      "steps": [
        {
          "id": "df",
          "title_ar": "تحديد القسم الممتلئ",
          "command": "df -hT",
          "explanation_ar": "يعرض الاستخدام ونوع نظام الملفات.",
          "requires_sudo": false,
          "risk": "low",
          "optional": false,
          "expected_result_ar": "تحديد القسم المرتفع.",
          "notes_ar": ""
        },
        {
          "id": "inodes",
          "title_ar": "فحص inodes",
          "command": "df -ih",
          "explanation_ar": "يتأكد أن المشكلة ليست نفاد inodes.",
          "requires_sudo": false,
          "risk": "low",
          "optional": false,
          "expected_result_ar": "نسب inodes.",
          "notes_ar": ""
        },
        {
          "id": "directories",
          "title_ar": "عرض أكبر المجلدات",
          "command": "sudo du -xhd1 <PATH> | sort -h",
          "explanation_ar": "يرتب أحجام المجلدات.",
          "requires_sudo": true,
          "risk": "low",
          "optional": false,
          "expected_result_ar": "قائمة مرتبة.",
          "notes_ar": ""
        },
        {
          "id": "files",
          "title_ar": "البحث عن الملفات الكبيرة",
          "command": "sudo find <PATH> -xdev -type f -size +500M -printf '%s %p\\n' | sort -n",
          "explanation_ar": "يعرض الملفات الأكبر من 500M.",
          "requires_sudo": true,
          "risk": "low",
          "optional": false,
          "expected_result_ar": "قائمة ملفات.",
          "notes_ar": ""
        },
        {
          "id": "deleted",
          "title_ar": "فحص الملفات المحذوفة المفتوحة",
          "command": "sudo lsof +L1",
          "explanation_ar": "يكشف ملفات محذوفة ما زالت مفتوحة.",
          "requires_sudo": true,
          "risk": "low",
          "optional": true,
          "expected_result_ar": "قائمة أو نتيجة فارغة.",
          "notes_ar": ""
        }
      ],
      "verification": [
        {
          "title_ar": "مراجعة المساحة",
          "command": "df -hT",
          "expected_result_ar": "انخفاض نسبة الاستخدام.",
          "requires_sudo": false
        }
      ],
      "rollback_ar": [
        "أنشئ نسخة احتياطية قبل حذف ملفات مهمة."
      ],
      "common_errors": [
        {
