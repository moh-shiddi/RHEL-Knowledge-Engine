          "requires_sudo": true,
          "risk": "high",
          "optional": false,
          "expected_result_ar": "إتمام الأمر.",
          "notes_ar": ""
        },
        {
          "id": "verify",
          "title_ar": "التحقق من المجموعات",
          "command": "id <USER>",
          "explanation_ar": "يجب أن تظهر wheel ضمن المجموعات.",
          "requires_sudo": false,
          "risk": "low",
          "optional": false,
          "expected_result_ar": "ظهور wheel.",
          "notes_ar": ""
        }
      ],
      "verification": [
        {
          "title_ar": "اختبار الهوية",
          "command": "id <USER>",
          "expected_result_ar": "ظهور المستخدم ومجموعة wheel.",
          "requires_sudo": false
        }
      ],
      "rollback_ar": [
        "sudo userdel -r <USER>"
      ],
      "common_errors": [
        {
          "symptom_ar": "المستخدم لا يستطيع استخدام sudo",
          "likely_causes_ar": [
            "لم تتم إضافته إلى wheel",
            "الجلسة القديمة لم تلتقط المجموعة"
