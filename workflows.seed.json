        {
          "id": "password",
          "title_ar": "تعيين كلمة المرور",
          "command": "sudo passwd <USER>",
          "explanation_ar": "يعيّن كلمة مرور الحساب.",
          "requires_sudo": true,
          "risk": "high",
          "optional": false,
          "expected_result_ar": "نجاح تحديث كلمة المرور.",
          "notes_ar": ""
        },
        {
          "id": "wheel",
          "title_ar": "إضافة المستخدم إلى wheel",
          "command": "sudo usermod -aG wheel <USER>",
